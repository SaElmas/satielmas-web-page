<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="course-detail-main">
        <section class="card course-card-section">
            <p class="course-category-label"><%= course.category[currentLang] %></p>
            <h1 class="course-title"><%= course.title[currentLang] %></h1>
            
            <p class="course-description">
                <%- course.description[currentLang] %>
            </p>

            <div class="course-grid">
                <div class="course-info-box">
                    <h3 class="course-info-title"><%= __('course_detail.lbl_curriculum') %></h3>
                    <ul class="course-syllabus-list">
                        <% if (course.syllabus && course.syllabus[currentLang]) { %>
                            <% course.syllabus[currentLang].forEach(function(item) { %>
                                <li><%- item %></li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>

                <div class="course-info-box">
                    <h3 class="course-info-title"><%= __('course_detail.lbl_strategy') %></h3>
                    <p class="course-strategy-text">
                        <%- course.examInfo[currentLang] %>
                    </p>
                <div class="course-btn-container">
                    <a href="/contact" class="course-trial-btn">
                        <%= __('course_detail.btn_trial') %>
                    </a>
                </div>
                </div>
            </div>
            
            <div class="course-back-container">
                <a href="/tutoring" class="course-back-link"><%= __('course_detail.link_back') %></a>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main>
        <section class="card">
            <h2>Get in Touch</h2>
            <p class="contact-intro">
                Whether you're looking for tutoring, academic collaboration, or just want to discuss mathematics and computer science, feel free to reach out.
            </p>

            <div class="contact-grid">
                <div class="contact-card contact-info">
                    <h3>Contact Information</h3>
                    <ul class="contact-list">
                        <li>
                            <i class="fas fa-map-marker-alt contact-icon" style="color: #ef4444;"></i> 
                            <strong>Location:</strong> Ankara, Türkiye
                        </li>
                        <li>
                            <a href="mailto:saitelmas@gmail.com">
                                <i class="fas fa-envelope contact-icon" style="color: #ea4335;"></i> 
                                <strong>Email:</strong> saitelmas@gmail.com
                            </a>
                        </li>
                        <li>
                            <a href="https://wa.me/905309537225" target="_blank">
                                <i class="fab fa-whatsapp contact-icon" style="color: #25d366;"></i> 
                                <strong>WhatsApp:</strong> +90 530 953 7225
                            </a>
                        </li>
                        <li>
                            <a href="https://linkedin.com/in/saitelmas" target="_blank">
                                <i class="fab fa-linkedin contact-icon" style="color: #0a66c2;"></i> 
                                <strong>LinkedIn:</strong> saitelmas
                            </a>
                        </li>
                        <li>
                            <a href="https://instagram.com/saitelmas_tutor" target="_blank">
                                <i class="fab fa-instagram contact-icon" style="color: #e1306c;"></i> 
                                <strong>Instagram:</strong> @saitelmas_tutor
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="contact-card contact-form">
                    <h3>Send a Message</h3>
                    <% if (typeof successMessage !== 'undefined') { %>
                    <div style="background-color: #d1fae5; color: #065f46; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; border: 1px solid #10b981;">
                        <i class="fas fa-check-circle"></i> <%= successMessage %>
                    </div>
                    <% } %>

                    <% if (typeof errorMessage !== 'undefined') { %>
                        <div style="background-color: #fee2e2; color: #991b1b; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; border: 1px solid #ef4444;">
                            <i class="fas fa-exclamation-circle"></i> <%= errorMessage %>
                        </div>
                    <% } %>
                    <form action="/contact" method="POST" class="form-container">
                        <div>
                            <label for="name" class="form-label">Name</label>
                            <input type="text" id="name" name="name" placeholder="Your Name" class="form-input" required>
                        </div>
                        <div>
                            <label for="email" class="form-label">Email</label>
                            <input type="email" id="email" name="email" placeholder="Your Email" class="form-input" required>
                        </div>
                        <div>
                            <label for="message" class="form-label">Message</label>
                            <textarea id="message" name="message" rows="4" placeholder="How can I help you?" class="form-input" required></textarea>
                        </div>
                        <button type="submit" class="submit-btn">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
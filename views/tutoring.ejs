<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="tutoring-content">
        
        <div class="giving-back-notice">
            <h3 class="giving-back-title">
                <span class="giving-back-icon">🌱</span> <%= __('tutoring_page.giving_back_title') %>
            </h3>
            <p class="giving-back-text">
                <%- __('tutoring_page.giving_back_text') %>
            </p>
        </div>

        <ul class="category-nav category-nav-wrapper">
            <li class="category-item">
                <a href="#"><%= __('tutoring_page.nav_high_school') %></a>
                <ul class="dropdown">
                    <li><a href="/tutoring/ap-calculus">AP Calculus AB & BC</a></li>
                    <li><a href="/tutoring/ap-statistics">AP Statistics</a></li>
                    <li><a href="/tutoring/ap-physics">AP Physics (1, 2, C)</a></li>
                    <li><a href="/tutoring/ap-computer-science">AP Computer Science</a></li>
                    <li><a href="/tutoring/ib-math">IB Math (AA & AI)</a></li>
                    <li><a href="/tutoring/ib-physics">IB Physics</a></li>
                    <li><a href="/tutoring/sat-math">SAT Math Prep</a></li>
                </ul>
            </li>
            <li class="category-item">
                <a href="#"><%= __('tutoring_page.nav_uni_math') %></a>
                <ul class="dropdown">
                    <li><a href="/tutoring/calculus">Calculus I-II-III</a></li>
                    <li><a href="/tutoring/linear-algebra">Linear Algebra</a></li>
                    <li><a href="/tutoring/differential-equations">Differential Equations</a></li>
                    <li><a href="/tutoring/real-complex-analysis">Real & Complex Analysis</a></li>
                    <li><a href="/tutoring/numerical-analysis">Numerical Analysis</a></li>
                    <li><a href="/tutoring/engineering-math">Engineering Math</a></li>
                </ul>
            </li>
            <li class="category-item">
                <a href="#"><%= __('tutoring_page.nav_uni_cs') %></a>
                <ul class="dropdown">
                    <li><a href="/tutoring/programming-languages">Python, C/C++, Java</a></li>
                    <li><a href="/tutoring/data-structures">Data Structures</a></li>
                    <li><a href="/tutoring/algorithm-design">Algorithm Design</a></li>
                    <li><a href="/tutoring/automata-theory">Automata Theory</a></li>
                    <li><a href="/tutoring/discrete-math">Discrete Mathematics</a></li>
                    <li><a href="/tutoring/database-systems">Database Systems</a></li>
                </ul>
            </li>
        </ul>

        <section class="exam-programs-section">
            <h2 class="section-title"><%= __('tutoring_page.exam_prep_title') %></h2>
            
            <div class="exam-grid">
                <div class="exam-card border-blue">
                    <h3><%= __('tutoring_page.exam_flexible_title') %></h3>
                    <p><%- __('tutoring_page.exam_flexible_desc') %></p>
                </div>

                <div class="exam-card border-green">
                    <h3><%= __('tutoring_page.exam_mock_title') %></h3>
                    <p><%- __('tutoring_page.exam_mock_desc') %></p>
                </div>

                <div class="exam-card border-orange">
                    <h3><%= __('tutoring_page.exam_strategic_title') %></h3>
                    <p><%- __('tutoring_page.exam_strategic_desc') %></p>
                </div>

                <div class="exam-card border-purple">
                    <h3><%= __('tutoring_page.exam_guarantee_title') %></h3>
                    <p><%- __('tutoring_page.exam_guarantee_desc') %></p>
                </div>
            </div>
        </section>

        <section class="stem-intro">
            <h1><%= __('tutoring_page.stem_intro_title') %></h1>
            <p><%= __('tutoring_page.stem_intro_desc') %></p>
            
            <div class="highlight-badges">
                <div class="feature-badge badge-blue">
                    <%= __('tutoring_page.badge_language') %>
                </div>
                <div class="feature-badge badge-green">
                    <%= __('tutoring_page.badge_online') %>
                </div>
                <div class="feature-badge badge-red">
                    <%= __('tutoring_page.badge_duration') %>
                </div>
            </div>
        </section>

        <section class="content">
            <div class="curriculum-grid">
                
                <div class="curriculum-box border-left-blue">
                    <h3><%= __('tutoring_page.box_ap_title') %></h3>
                    <ul>
                        <li><%- __('tutoring_page.box_ap_math') %></li>
                        <li><%- __('tutoring_page.box_ap_physics') %></li>
                        <li><%- __('tutoring_page.box_ap_cs') %></li>
                    </ul>
                </div>

                <div class="curriculum-box border-left-red">
                    <h3><%= __('tutoring_page.box_ib_title') %></h3>
                    <ul>
                        <li><%- __('tutoring_page.box_ib_math') %></li>
                        <li><%- __('tutoring_page.box_ib_physics') %></li>
                        <li><%- __('tutoring_page.box_ib_cs') %></li>
                    </ul>
                </div>

                <div class="curriculum-box border-left-orange">
                    <h3><%= __('tutoring_page.box_sat_title') %></h3>
                    <ul>
                        <li><%- __('tutoring_page.box_sat_math') %></li>
                    </ul>
                </div>

                <div class="curriculum-box border-left-green">
                    <h3><%= __('tutoring_page.box_uni_math_title') %></h3>
                    <ul>
                        <li><%- __('tutoring_page.box_uni_math_core') %></li>
                        <li><%- __('tutoring_page.box_uni_math_algebra') %></li>
                        <li><%- __('tutoring_page.box_uni_math_applied') %></li>
                        <li><%- __('tutoring_page.box_uni_math_physics') %></li>
                    </ul>
                </div>

                <div class="curriculum-box border-left-purple">
                    <h3><%= __('tutoring_page.box_uni_cs_title') %></h3>
                    <ul>
                        <li><%- __('tutoring_page.box_uni_cs_prog') %></li>
                        <li><%- __('tutoring_page.box_uni_cs_core') %></li>
                        <li><%- __('tutoring_page.box_uni_cs_systems') %></li>
                    </ul>
                </div>

            </div>
        </section>
    </main>

    <div class="university-slider-fullwidth">
        <div class="slider-track">
            <div class="text-card">Middle East Technical Univ. (METU)</div>
            <div class="text-card">Istanbul Technical Univ. (ITU)</div>
            <div class="text-card">Bogazici University</div>
            <div class="text-card">Bilkent University</div>
            <div class="text-card">Koc University</div>
            <div class="text-card">Sabanci University</div>
            <div class="text-card">Yildiz Technical Univ. (YTU)</div>
            <div class="text-card">Izmir Inst. of Technology (IZTECH)</div>
            <div class="text-card">Hacettepe University</div>
            <div class="text-card">Galatasaray University</div>
            <div class="text-card">Gebze Technical Univ. (GTU)</div>
            <div class="text-card">Ankara University</div>
            <div class="text-card">Gazi University</div>
            <div class="text-card">Ege University</div>
            <div class="text-card">Marmara University</div>
            <div class="text-card">Middle East Technical Univ. (METU)</div>
            <div class="text-card">Istanbul Technical Univ. (ITU)</div>
            <div class="text-card">Bogazici University</div>
            <div class="text-card">Bilkent University</div>
            <div class="text-card">Koc University</div>
            <div class="text-card">Sabanci University</div>
            <div class="text-card">Yildiz Technical Univ. (YTU)</div>
            <div class="text-card">Izmir Inst. of Technology (IZTECH)</div>
            <div class="text-card">Hacettepe University</div>
            <div class="text-card">Galatasaray University</div>
            <div class="text-card">Gebze Technical Univ. (GTU)</div>
            <div class="text-card">Ankara University</div>
            <div class="text-card">Gazi University</div>
            <div class="text-card">Ege University</div>
            <div class="text-card">Marmara University</div>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>
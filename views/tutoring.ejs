<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>
    <style>
        /* Yatay Alt Menü (Sub-nav) Tasarımı */
        .category-nav {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            margin: 0 auto 2rem auto;
            max-width: 1200px;
            display: flex;
            justify-content: center;
            list-style: none;
            padding: 0;
            position: relative;
            z-index: 50; /* Açılır menünün kartların üstünde kalmasını sağlar */
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .category-item {
            position: relative;
            flex: 1; /* Menüleri eşit genişlikte yayar */
            text-align: center;
        }

        .category-item > a {
            display: block;
            padding: 1.2rem 2rem;
            color: #0f172a;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border-bottom: 3px solid transparent;
        }

        .category-item:hover > a {
            color: #3b82f6;
            border-bottom: 3px solid #3b82f6;
            background: #f8fafc;
        }

        /* Açılır Menü (Dropdown) */
        .dropdown {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            background: #ffffff;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-radius: 0 0 8px 8px;
            border: 1px solid #e2e8f0;
            border-top: none;
            padding: 0.5rem 0;
            list-style: none;
            text-align: left;
        }

        .category-item:hover .dropdown {
            display: block;
        }

        .dropdown li a {
            display: block;
            padding: 0.75rem 1.5rem;
            color: #475569;
            text-decoration: none;
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        .dropdown li a:hover {
            background: #f8fafc;
            color: #3b82f6;
            padding-left: 2rem; /* Üzerine gelince metnin hafif sağa kayma efekti */
        }

        /* Sayfa Düzeni */
        .tutoring-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        /* Mobil Uyumluluk */
        @media (max-width: 768px) {
            .category-nav {
                flex-direction: column;
            }
            .category-item {
                border-bottom: 1px solid #e2e8f0;
            }
            .category-item:last-child {
                border-bottom: none;
            }
            .dropdown {
                position: static;
                box-shadow: none;
                border: none;
                background: #f8fafc;
                display: none;
            }
            /* Mobilde tıklanınca/fokuslanınca açılsın diye hover korundu, CSS destekler */
        }
    </style>

    <main class="tutoring-content">
        <ul class="category-nav">
            <li class="category-item">
                <a href="#">High School ▾</a>
                <ul class="dropdown">
                    <li><a href="/tutoring/ap-calculus">AP Calculus AB & BC</a></li>
                    <li><a href="/tutoring/ap-statistics">AP Statistics</a></li>
                    <li><a href="/tutoring/ap-physics">AP Physics (1, 2, C)</a></li>
                    <li><a href="/tutoring/ap-computer-science">AP Computer Science</a></li>
                    <li><a href="/tutoring/ib-math">IB Math (AA & AI)</a></li>
                    <li><a href="/tutoring/ib-physics">IB Physics</a></li>
                    <li><a href="/tutoring/sat-math">SAT Math Prep</a></li>
                </ul>
            </li>
            <li class="category-item">
                <a href="#">University Math ▾</a>
                <ul class="dropdown">
                    <li><a href="/tutoring/calculus">Calculus I-II-III</a></li>
                    <li><a href="/tutoring/linear-algebra">Linear Algebra</a></li>
                    <li><a href="/tutoring/differential-equations">Differential Equations</a></li>
                    <li><a href="/tutoring/real-complex-analysis">Real & Complex Analysis</a></li>
                    <li><a href="/tutoring/numerical-analysis">Numerical Analysis</a></li>
                    <li><a href="/tutoring/engineering-math">Engineering Math</a></li>
                </ul>
            </li>
            <li class="category-item">
                <a href="#">University CS ▾</a>
                <ul class="dropdown">
                    <li><a href="/tutoring/programming-languages">Python, C/C++, Java</a></li>
                    <li><a href="/tutoring/data-structures">Data Structures</a></li>
                    <li><a href="/tutoring/algorithm-design">Algorithm Design</a></li>
                    <li><a href="/tutoring/automata-theory">Automata Theory</a></li>
                    <li><a href="/tutoring/discrete-math">Discrete Mathematics</a></li>
                    <li><a href="/tutoring/database-systems">Database Systems</a></li>
                </ul>
            </li>
        </ul>

        <section class="content">
            <h2 style="margin-top: 0; text-align: center;">STEM Tutoring & Lecturing</h2>
            <p style="font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem; text-align: center;">
                I specialize in providing high-quality, structured tutoring for high school and university students across international curricula. My approach focuses on deep conceptual understanding and rigorous problem-solving.
            </p>
            
            <div class="curriculum-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                
                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #3b82f6;">
                    <h3 style="color: #0f172a; margin-top: 0;">AP (Advanced Placement)</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Calculus AB & BC, Statistics</li>
                        <li><strong>Physics:</strong> Physics 1, 2, and Physics C (Mechanics & E&M)</li>
                        <li><strong>Computer Science:</strong> Computer Science A, Computer Science Principles</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #ef4444;">
                    <h3 style="color: #0f172a; margin-top: 0;">IB (International Baccalaureate)</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Analysis and Approaches (AA), Applications and Interpretation (AI) - HL & SL</li>
                        <li><strong>Physics:</strong> Higher Level (HL) & Standard Level (SL)</li>
                        <li><strong>Computer Science:</strong> Higher Level (HL) & Standard Level (SL)</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #f59e0b;">
                    <h3 style="color: #0f172a; margin-top: 0;">SAT Preparation</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Comprehensive SAT Math preparation, advanced problem-solving, and timing strategies.</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #10b981;">
                    <h3 style="color: #0f172a; margin-top: 0;">University Math & Physics</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Core Calculus & Analysis:</strong> Calculus I-II-III (Multivariable), Advanced Calculus, Real Analysis, Complex Analysis</li>
                        <li><strong>Algebra & Geometry:</strong> Linear Algebra, Abstract Algebra, Differential Geometry</li>
                        <li><strong>Applied & Engineering Math:</strong> Ordinary & Partial Differential Equations (ODE & PDE), Numerical Analysis, Engineering Mathematics, Probability & Statistics</li>
                        <li><strong>Physics:</strong> University General Physics (Mechanics & Electromagnetism)</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #8b5cf6;">
                    <h3 style="color: #0f172a; margin-top: 0;">University Computer Science</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Programming Languages:</strong> Python, C, C++, Java</li>
                        <li><strong>Core CS & Theory:</strong> Data Structures, Algorithm Design, Automata Theory, Discrete Mathematics</li>
                        <li><strong>Systems & Hardware:</strong> Database Systems, Computer Architecture, Circuit Design</li>
                    </ul>
                </div>

            </div>
        </section>
    </main>


    <!-- Üniversiteler Metin Kayar Bant Başlangıcı -->
    <style>
        /* Slider kapsayıcısını baştan uca tam ekran yapıyoruz */
        .university-slider-fullwidth {
            width: 100%;
            background-color: #ffffff;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            padding: 2rem 0;
            margin-top: 3rem;
            overflow: hidden;
            position: relative;
            display: flex;
        }

        .slider-track {
            display: flex;
            /* 15 kart + 15 kopya = 30 kart. Kart genişliği (250px) + boşluk (1rem=16px) */
            width: calc((250px + 16px) * 30); 
            animation: scrollText 40s linear infinite;
            align-items: center;
            gap: 16px;
        }

        .slider-track:hover {
            animation-play-state: paused;
        }

        .text-card {
            width: 250px;
            height: 70px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            font-weight: 600;
            color: #334155;
            font-size: 0.95rem;
            padding: 0 1rem;
            transition: all 0.3s ease;
            cursor: default;
            box-sizing: border-box;
        }

        .text-card:hover {
            background: #0f172a;
            color: #ffffff;
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-color: #0f172a;
        }

        @keyframes scrollText {
            0% { transform: translateX(0); }
            100% { transform: translateX(calc((-250px - 16px) * 15)); } 
        }
    </style>

    <div class="university-slider-fullwidth">
        <div class="slider-track">
            <!-- Orijinal 15 Üniversite Kartı -->
            <div class="text-card">Orta Doğu Teknik Üni. (ODTÜ)</div>

        <div class="text-card">Gazi Üniversitesi</div>
        <div class="text-card">Ege Üniversitesi</div>
        <div class="text-card">Marmara Üniversitesi</div>

        <!-- Animasyonun kesintisiz dönmesi için 15 kartı kopyalıyoruz -->
        <div class="text-card">Orta Doğu Teknik Üni. (ODTÜ)</div>
        <div class="text-card">İstanbul Teknik Üni. (İTÜ)</div>

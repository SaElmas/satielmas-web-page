<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

<style>
        /* Sidebar ve İçerik Düzeni (Grid) */
        .tutoring-layout {
            display: grid;
            grid-template-columns: 280px 1fr; /* Sol 280px sidebar, sağ taraf kalan tüm boşluk */
            gap: 2.5rem;
            align-items: start; /* Sidebar'ın aşağı uzamasını engeller, sticky için şarttır */
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        /* Sidebar Tasarımı ve Yapışkan Özelliği */
        .sidebar {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 1.5rem;
            position: sticky;
            top: 2rem; /* Kaydırırken yukarıda bırakılacak boşluk */
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .sidebar h3 {
            color: #0f172a;
            font-size: 1.1rem;
            margin-top: 0;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
            margin: 0 0 1.5rem 0;
        }

        .sidebar ul:last-child {
            margin-bottom: 0;
        }

        .sidebar li {
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
            color: #475569;
            display: flex;
            align-items: center;
        }

        .sidebar li::before {
            content: "▸";
            color: #3b82f6; /* Mavi ok işareti */
            margin-right: 0.5rem;
            font-size: 1.2rem;
        }

        /* Mobil Cihazlar İçin Uyumluluk (Responsive) */
        @media (max-width: 900px) {
            .tutoring-layout {
                grid-template-columns: 1fr; /* Mobilde tek sütun yap */
            }
            .sidebar {
                position: static; /* Mobilde yapışkan özelliği kapat */
                margin-bottom: 2rem;
            }
        }
    </style>

    <main class="tutoring-layout">
        <aside class="sidebar">
            <h3>High School</h3>
            <ul>
                <li>AP Calculus AB & BC</li>
                <li>AP Statistics</li>
                <li>AP Physics (1, 2, C)</li>
                <li>AP Computer Science</li>
                <li>IB Math (AA & AI)</li>
                <li>IB Physics</li>
                <li>SAT Math Prep</li>
            </ul>

            <h3>University Math</h3>
            <ul>
                <li>Calculus I-II-III</li>
                <li>Linear Algebra</li>
                <li>Differential Equations</li>
                <li>Real & Complex Analysis</li>
                <li>Numerical Analysis</li>
                <li>Engineering Math</li>
            </ul>

            <h3>University CS</h3>
            <ul>
                <li>Python, C/C++, Java</li>
                <li>Data Structures</li>
                <li>Algorithm Design</li>
                <li>Automata Theory</li>
                <li>Discrete Mathematics</li>
                <li>Database Systems</li>
            </ul>
        </aside>

        <section class="content">
            <h2 style="margin-top: 0;">STEM Tutoring & Lecturing</h2>
            <p style="font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem;">
                I specialize in providing high-quality, structured tutoring for high school and university students across international curricula. My approach focuses on deep conceptual understanding and rigorous problem-solving.
            </p>
            
            <div class="curriculum-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
                
                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #3b82f6;">
                    <h3 style="color: #0f172a; margin-top: 0;">AP (Advanced Placement)</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Calculus AB & BC, Statistics</li>
                        <li><strong>Physics:</strong> Physics 1, 2, and Physics C (Mechanics & E&M)</li>
                        <li><strong>Computer Science:</strong> Computer Science A, Computer Science Principles</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #ef4444;">
                    <h3 style="color: #0f172a; margin-top: 0;">IB (International Baccalaureate)</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Analysis and Approaches (AA), Applications and Interpretation (AI) - HL & SL</li>
                        <li><strong>Physics:</strong> Higher Level (HL) & Standard Level (SL)</li>
                        <li><strong>Computer Science:</strong> Higher Level (HL) & Standard Level (SL)</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #f59e0b;">
                    <h3 style="color: #0f172a; margin-top: 0;">SAT Preparation</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Mathematics:</strong> Comprehensive SAT Math preparation, advanced problem-solving, and timing strategies.</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #10b981;">
                    <h3 style="color: #0f172a; margin-top: 0;">University Math & Physics</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Core Calculus & Analysis:</strong> Calculus I-II-III (Multivariable), Advanced Calculus, Real Analysis, Complex Analysis</li>
                        <li><strong>Algebra & Geometry:</strong> Linear Algebra, Abstract Algebra, Differential Geometry</li>
                        <li><strong>Applied & Engineering Math:</strong> Ordinary & Partial Differential Equations (ODE & PDE), Numerical Analysis, Engineering Mathematics, Probability & Statistics</li>
                        <li><strong>Physics:</strong> University General Physics (Mechanics & Electromagnetism)</li>
                    </ul>
                </div>

                <div class="curriculum-box" style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #8b5cf6;">
                    <h3 style="color: #0f172a; margin-top: 0;">University Computer Science</h3>
                    <ul style="list-style-type: square; margin-left: 1rem;">
                        <li><strong>Programming Languages:</strong> Python, C, C++, Java</li>
                        <li><strong>Core CS & Theory:</strong> Data Structures, Algorithm Design, Automata Theory, Discrete Mathematics</li>
                        <li><strong>Systems & Hardware:</strong> Database Systems, Computer Architecture, Circuit Design</li>
                    </ul>
                </div>

            </div>
        </section>
    </main>

<!-- Üniversiteler Metin Kayar Bant Başlangıcı -->
<style>
    /* Slider kapsayıcısını baştan uca tam ekran yapıyoruz */
    .university-slider-fullwidth {
        width: 100%;
        background-color: #ffffff;
        border-top: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
        padding: 2rem 0;
        margin-top: 3rem;
        overflow: hidden;
        position: relative;
        display: flex;
    }

    .slider-track {
        display: flex;
        /* 15 kart + 15 kopya = 30 kart. Kart genişliği (250px) + boşluk (1rem=16px) */
        width: calc((250px + 16px) * 30); 
        animation: scrollText 40s linear infinite;
        align-items: center;
        gap: 16px;
    }

    .slider-track:hover {
        animation-play-state: paused;
    }

    .text-card {
        width: 250px;
        height: 70px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        font-weight: 600;
        color: #334155;
        font-size: 0.95rem;
        padding: 0 1rem;
        transition: all 0.3s ease;
        cursor: default;
        box-sizing: border-box;
    }

    .text-card:hover {
        background: #0f172a;
        color: #ffffff;
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border-color: #0f172a;
    }

    @keyframes scrollText {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc((-250px - 16px) * 15)); } 
    }
</style>

<div class="university-slider-fullwidth">
    <div class="slider-track">
        <!-- Orijinal 15 Üniversite Kartı -->
        <div class="text-card">Orta Doğu Teknik Üni. (ODTÜ)</div>
